# =============================================================================
# Конфигурация хост-сервиса awwwdde. Скопировать в .env и заполнить.
#   cp .env.example .env
# =============================================================================

# Базовый домен платформы. Поддомены гостей: <slug>.<BASE_DOMAIN>
BASE_DOMAIN=awwwdde.art

# БД панели. Локально — SQLite. В проде — Postgres:
#   DATABASE_URL=postgresql://awwwdde:PASS@panel_db:5432/awwwdde
DATABASE_URL=sqlite:///./awwwdde.db

# Caddy Admin API (на хосте, где крутится Caddy).
CADDY_ADMIN_URL=http://localhost:2019
CADDY_SERVER=srv0

# Общая docker-сеть для всех гостевых контейнеров.
DOCKER_NETWORK=awwwdde_net

# Порт, на котором гостевой app слушает ВНУТРИ контейнера (контракт).
GUEST_APP_PORT=8080

# Где хранить исходники гостевых проектов.
WORKSPACES_DIR=./workspaces

# Bearer-токен для API/CLI. Сгенерировать:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=dev-token-change-me
