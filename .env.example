# =============================================================================
# Переменные хост-стека awwwdde. Скопировать в .env: cp .env.example .env
# =============================================================================

# Базовый домен платформы (без https://). Гости: <slug>.awwwdde.art
BASE_DOMAIN=awwwdde.art

# Email для Let's Encrypt.
ACME_EMAIL=you@example.com

# Токен DNS-провайдера для wildcard-сертификата *.awwwdde.art.
CF_API_TOKEN=__REPLACE_ME__

# Пароль БД самой панели (отдельной от гостевых БД).
#   openssl rand -base64 24
PANEL_DB_PASSWORD=__REPLACE_ME_strong_password__

# URL БД панели. В docker-compose панель ходит в сервис panel_db по имени:
DATABASE_URL=postgresql://awwwdde:__REPLACE_ME_strong_password__@panel_db:5432/awwwdde
# Для локальной разработки (panel запускается uvicorn'ом вне compose):
# DATABASE_URL=postgresql://awwwdde:awwwdde@localhost:5432/awwwdde

# Bearer-токен API панели (его же использует CLI: AWWWDDE_TOKEN).
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=__REPLACE_ME_long_random_token__

# Секрет подписи JWT для веб-админки.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=__REPLACE_ME_jwt_signing_secret__
