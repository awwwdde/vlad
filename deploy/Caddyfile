# Базовая конфигурация Caddy для платформы awwwdde.
#
#   • Admin API открыт на 0.0.0.0:2019 — панель добавляет/убирает маршруты
#     гостей через REST (см. back/caddy.py).
#   • Apex {$DOMAIN}: отдаём SPA-портфолио + проксируем /api/* в панель.
#   • Под-сайты <slug>.{$DOMAIN}: маршруты пишет панель на лету, Caddy
#     автоматически выпускает HTTP-01 сертификат при первом запросе.
#     Чтобы это работало, *.awwwdde.art должен резолвиться на этот IP
#     (wildcard A-запись в DNS-провайдере).

{
	email {$ACME_EMAIL}
	# Admin API доступен другим контейнерам сети (не только localhost).
	admin 0.0.0.0:2019
}

# ── Основной сайт + admin (apex домен) ───────────────────────────────────────
{$DOMAIN} {
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	# API панели — всё под /api/* идёт в FastAPI.
	@api path /api/* /healthz
	handle @api {
		reverse_proxy panel:8000
	}

	# Статика SPA из общего volume (его наполняет сервис `front` в compose).
	handle {
		root * /srv/front
		try_files {path} /index.html
		file_server
	}

	log {
		output stdout
		format console
	}
}
